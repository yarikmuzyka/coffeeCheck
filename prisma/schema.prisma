// coffeeCheck — Coffee Tracker / Brew Journal
// PostgreSQL (Neon/Supabase/Vercel Postgres) для деплою на Vercel.
//   DATABASE_URL — пулований конект (runtime у serverless)
//   DIRECT_URL   — прямий конект (для `prisma db push` / migrate)

generator client {
  provider      = "prisma-client-js"
  // native — для локалі; rhel-openssl-3.0.x — для рантайму Vercel (Amazon Linux)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Process {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}

model Roaster {
  id        String   @id @default(cuid())
  name      String
  country   String?
  city      String?
  website   String?
  instagram String?
  notes     String?
  coffees   Coffee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coffee {
  id            String    @id @default(cuid())
  name          String
  roasterId     String
  roaster       Roaster   @relation(fields: [roasterId], references: [id], onDelete: Cascade)
  originCountry String?
  region        String?
  variety       String?
  process       String?
  scaScore      Float?
  myScore       Float?
  purchaseDate  DateTime?
  price         Float?
  isFinished    Boolean   @default(false)
  wouldBuyAgain Boolean?
  brewLogs      BrewLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BrewLog {
  id              String   @id @default(cuid())
  coffeeId        String
  coffee          Coffee   @relation(fields: [coffeeId], references: [id], onDelete: Cascade)
  brewedAt        DateTime @default(now())
  method          String
  recipeName      String?
  doseGrams       Float?
  waterGrams      Float?
  ratio           String?
  grindSize       String?
  grinder         String?
  waterName       String?
  waterTempC      Float?
  brewTimeSeconds Int?
  filterType      String?
  brewer          String?

  // Rating
  overallScore    Int?
  aromaScore      Int?
  acidityScore    Int?
  sweetnessScore  Int?
  bodyScore       Int?
  aftertasteScore Int?
  balanceScore    Int?
  perceivedNotes  String?
  defects         String?
  notes           String?
  wouldBrewAgain  Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
