// coffee logger — Coffee Tracker / Brew Journal
// PostgreSQL (Neon/Supabase/Vercel Postgres) для деплою на Vercel.
//   DATABASE_URL — пулований конект (runtime у serverless)
//   DIRECT_URL   — прямий конект (для `prisma db push` / migrate)

generator client {
  provider      = "prisma-client-js"
  // native — для локалі; rhel-openssl-3.0.x — для рантайму Vercel (Amazon Linux)
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PRO
}

model Process {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation("UserProcesses", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Roaster {
  id        String   @id @default(cuid())
  name      String
  country   String?
  city      String?
  website   String?
  instagram String?
  notes     String?
  userId    String
  user      User     @relation("UserRoasters", fields: [userId], references: [id], onDelete: Cascade)
  coffees   Coffee[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Coffee {
  id            String    @id @default(cuid())
  name          String
  roasterId     String
  roaster       Roaster   @relation(fields: [roasterId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation("UserCoffees", fields: [userId], references: [id], onDelete: Cascade)
  originCountry String?
  region        String?
  variety       String?
  process       String?
  scaScore      Float?
  myScore       Float?
  purchaseDate  DateTime?
  price         Float?
  isFinished    Boolean   @default(false)
  wouldBuyAgain Boolean?
  brewLogs      BrewLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([userId, roasterId])
}

model BrewLog {
  id              String   @id @default(cuid())
  coffeeId        String
  coffee          Coffee   @relation(fields: [coffeeId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation("UserBrewLogs", fields: [userId], references: [id], onDelete: Cascade)
  brewedAt        DateTime @default(now())
  method          String
  recipeName      String?
  doseGrams       Float?
  waterGrams      Float?
  ratio           String?
  grindSize       String?
  grinder         String?
  waterName       String?
  waterTempC      Float?
  brewTimeSeconds Int?
  filterType      String?
  brewer          String?

  // Rating
  overallScore    Int?
  aromaScore      Int?
  acidityScore    Int?
  sweetnessScore  Int?
  bodyScore       Int?
  aftertasteScore Int?
  balanceScore    Int?
  perceivedNotes  String?
  defects         String?
  notes           String?
  wouldBrewAgain  Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, coffeeId])
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  plan          Plan              @default(FREE)
  accounts      Account[]
  sessions      Session[]
  processes     Process[]         @relation("UserProcesses")
  roasters      Roaster[]         @relation("UserRoasters")
  coffees       Coffee[]          @relation("UserCoffees")
  brewLogs      BrewLog[]         @relation("UserBrewLogs")
  rateLimits    RateLimitBucket[]
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  windowStart DateTime
  count       Int      @default(1)

  @@unique([userId, action, windowStart])
  @@index([windowStart])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
