# PostgreSQL (Neon / Supabase / Vercel Postgres)
#
# DATABASE_URL — пулований конект (використовується в рантаймі, serverless).
#   Для Neon це рядок з хостом *-pooler..., додай ?sslmode=require&pgbouncer=true
# DIRECT_URL   — прямий конект (для `prisma db push` / `prisma migrate`).
#   Для Neon це рядок БЕЗ -pooler, додай ?sslmode=require

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/coffeecheck?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/coffeecheck?sslmode=require"

# Auth.js + Google OAuth
# Callback URL у Google Cloud:
# http://localhost:3000/api/auth/callback/google (local)
# https://your-domain.example/api/auth/callback/google (production)
AUTH_GOOGLE_ID="replace-with-google-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-client-secret"
AUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Локально довіряємо Host заголовку; Vercel Auth.js розпізнає автоматично.
AUTH_TRUST_HOST="true"

# Лише для одноразового backfill існуючих single-user даних після першого Google-входу.
OWNER_EMAIL="owner@example.com"
